<idea-plugin>
  <id>eu.nahoj.jetbrains.mddetails</id>
  <name>Collapse Markdown Details</name>
  <version>1.0.0</version>
  <vendor email="nahoj@crans.org">You</vendor>
  <description>
    Automatically folds HTML &lt;details&gt; sections in Markdown files by default and shows the &lt;summary&gt; text as the placeholder.
  </description>

  <!-- Platform + Markdown -->
  <depends>com.intellij.modules.platform</depends>
  <depends>org.intellij.plugins.markdown</depends>

  <!-- Compatible with 2025.2+ (build 252+) -->
  <idea-version since-build="252"/>

  <extensions defaultExtensionNs="com.intellij">
    <lang.foldingBuilder language="Markdown"
                         implementationClass="eu.nahoj.jetbrains.mddetails.MarkdownDetailsFoldingBuilder"/>
  </extensions>
</idea-plugin>
